    {
      "itemIdentifier": "ogc.bioclima.zonification.bioclimatic-zone",
      "name": "Bioclimatic Zonification from PCI",
      "abstract": "Aggregated zonification derived from the PCI raster. The Python implementation (code/zonify.py) classifies every PCI pixel into one of four categories using published thresholds (stable, mild advance, strong advance, delay) and then groups spatially-contiguous pixels of the same category into a single MultiPolygon Feature with summary statistics (area, mean PCI, n pixels). This produces semantically-meaningful zones \u2014 not individual grid cells \u2014 and emits a GeoJSON FeatureCollection where every Feature carries the SKOS IRI of its category, the KMGBF targets it informs, and a provenance pointer to the upstream PCI bblock.",
      "status": "under-development",
      "dateTimeAddition": "2024-11-01T00:00:00Z",
      "itemClass": "datatype",
      "register": "bioclima",
      "group": "zonification",
