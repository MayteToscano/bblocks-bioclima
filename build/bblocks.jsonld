        "bblocks://ogc.bioclima.provenance.indicator-provenance",
        "bblocks://ogc.bioclima.ebv.vap-deciduous",
        "bblocks://ogc.bioclima.indicator",
        "bblocks://ogc.bioclima.coveragejson.bioclima-coverage"
      ],
