    {
      "itemIdentifier": "ogc.bioclima.policy.policy-alignment",
      "name": "Indicator \u2194 Policy Alignment",
      "abstract": "Schema describing how a Bioclima indicator aligns with a KMGBF target or an SDG goal. Every alignment record states a relationship type (informs, measures-progress-on, triggers-action-for, supports-reporting-on), an evidence strength (direct, indirect, contextual) and a multilingual justification. This block is the semantic bridge between gridded indicators (PCI, zonification) and the policy frameworks they support, and is what makes the register actionable for policy-makers.",
      "status": "under-development",
      "dateTimeAddition": "2024-11-01T00:00:00Z",
      "itemClass": "schema",
      "register": "bioclima",
      "group": "policy",
