<bblocks://ogc.bioclima.indicator.pci> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Datatype ;
    rdfs:label "Phenological Change Indicator (PCI)" ;
    dct:abstract "Composite indicator of phenological change. PCI is published as a single CoverageJSON with a ParameterGroup of four parameters per pixel: trend (Theil-Sen slope of VAP day-of-year over the analysis window), anomaly (recent-vs-baseline mean difference), changepoint_year (Pettitt test) and changepoint_pvalue. Every parameter declares its observedProperty in the Bioclima ontology, so an analyst clicking a pixel in the viewer can navigate to the formal definition of each component. The bundle ships with code/compute.py and a worked example for Finland 2001-2018, and declares a formal policy alignment with KMGBF Target 8 and SDG 15."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2024-11-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/bblocks/bblock/ogc.bioclima.indicator.pci> ],
        [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/build/generateddocs/json-full/bioclima/indicator/pci/index.json> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/build/generateddocs/markdown/bioclima/indicator/pci/index.md> ] ;
    dct:hasVersion "0.2.0" ;
    dct:modified "2024-11-01"^^xsd:date ;
    dct:source <https://maytetoscano.github.io/bblocks-bioclima/viewer/>,
        <https://maytetoscano.github.io/bblocks-bioclima/viewer/?layer=pci>,
        <https://maytetoscano.github.io/bblocks-bioclima/viewer/registry.html#fam-indicator> ;
    skos:closeMatch <https://maytetoscano.github.io/bblocks-bioclima/ontology/indicator/pci>,
        <https://maytetoscano.github.io/bblocks-bioclima/ontology/indicator/pci-trend> ;
    skos:inScheme <https://maytetoscano.github.io/bblocks-bioclima/> ;
    skos:prefLabel "Phenological Change Indicator (PCI)" ;
    skos:topConceptOf <https://maytetoscano.github.io/bblocks-bioclima/> ;
    dcat:keyword "anomaly",
        "changepoint",
        "family-indicator",
        "pci",
        "phenology",
        "trend" ;
    prof:hasResource [ rdfs:label "Ontology concept: pci-trend" ;
            ns2:relation <http://www.iana.org/assignments/relation/described-by> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/ontology/indicator/pci-trend> ],
        [ rdfs:label "Family: Spatial Indicators" ;
