            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/registry.html> ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://maytetoscano.github.io/bblocks-bioclima/build/annotated/bioclima/ebv/ebv-definition/schema.json> ;
            prof:hasRole role:schema ],
        [ rdfs:label "Bioclima interactive viewer" ;
            ns2:relation <http://www.iana.org/assignments/relation/viewer> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/> ],
        [ rdfs:label "Family: EBVs (Essential Biodiversity Variables)" ;
            ns2:relation <http://www.iana.org/assignments/relation/classified-under> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/registry.html#fam-ebv> ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
