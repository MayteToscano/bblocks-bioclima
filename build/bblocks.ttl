            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/?layer=pci> ],
        [ rdfs:label "Policy alignment record for PCI" ;
            ns2:relation <http://www.iana.org/assignments/relation/policy-alignment> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/_sources/policy/policy-alignment/examples/pci-alignment.jsonld> ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
