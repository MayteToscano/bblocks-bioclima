        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/bblocks/bblock/ogc.bioclima.coveragejson> ] ;
    dct:hasVersion "0.1.0" ;
