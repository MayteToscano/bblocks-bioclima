<bblocks://ogc.bioclima.coveragejson> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Model ;
    rdfs:label "CoverageJSON / BioClima Coverage" ;
    dct:abstract "Family block for the BioClima CoverageJSON profile. It groups the reusable CoverageJSON constraints used by EBV datasets, derived indicators and zonification outputs."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2024-11-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
