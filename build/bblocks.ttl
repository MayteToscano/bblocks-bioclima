<bblocks://ogc.bioclima.zonification.bioclimatic-zone> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Datatype ;
    rdfs:label "Bioclimatic Zonification from PCI" ;
    dct:abstract "Aggregated zonification derived from the PCI raster. The Python implementation (code/zonify.py) classifies every PCI pixel into one of four categories using published thresholds (stable, mild advance, strong advance, delay) and then groups spatially-contiguous pixels of the same category into a single MultiPolygon Feature with summary statistics (area, mean PCI, n pixels). This produces semantically-meaningful zones — not individual grid cells — and emits a GeoJSON FeatureCollection where every Feature carries the SKOS IRI of its category, the KMGBF targets it informs, and a provenance pointer to the upstream PCI bblock."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2024-11-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/build/generateddocs/json-full/bioclima/zonification/bioclimatic-zone/index.json> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/bblocks/bblock/ogc.bioclima.zonification.bioclimatic-zone> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/build/generateddocs/markdown/bioclima/zonification/bioclimatic-zone/index.md> ] ;
    dct:hasVersion "0.2.0" ;
    dct:modified "2024-11-01"^^xsd:date ;
    dct:source <https://maytetoscano.github.io/bblocks-bioclima/viewer/>,
        <https://maytetoscano.github.io/bblocks-bioclima/viewer/?layer=bioclimatic-zones>,
        <https://maytetoscano.github.io/bblocks-bioclima/viewer/registry.html#fam-zonification> ;
    skos:closeMatch <https://maytetoscano.github.io/bblocks-bioclima/ontology/indicator/zone-category> ;
    skos:inScheme <https://maytetoscano.github.io/bblocks-bioclima/> ;
    skos:prefLabel "Bioclimatic Zonification from PCI" ;
    skos:topConceptOf <https://maytetoscano.github.io/bblocks-bioclima/> ;
    dcat:keyword "aggregation",
        "bioclimatic",
        "family-zonification",
        "geojson",
        "zone" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://maytetoscano.github.io/bblocks-bioclima/build/annotated/bioclima/zonification/bioclimatic-zone/schema.json> ;
            prof:hasRole role:schema ],
        [ rdfs:label "Bioclima registry index (by family)" ;
            ns2:relation <http://www.iana.org/assignments/relation/registry-index> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/registry.html> ],
        [ rdfs:label "Ontology concept: zone-category" ;
            ns2:relation <http://www.iana.org/assignments/relation/described-by> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/ontology/indicator/zone-category> ],
        [ rdfs:label "Open zones in the viewer" ;
            ns2:relation <http://www.iana.org/assignments/relation/viewer-layer> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/?layer=bioclimatic-zones> ],
        [ rdfs:label "Family: Bioclimatic Zonification" ;
            ns2:relation <http://www.iana.org/assignments/relation/classified-under> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/viewer/registry.html#fam-zonification> ],
        [ rdfs:label "Upstream indicator: PCI" ;
            ns2:relation <http://www.iana.org/assignments/relation/derived-from> ;
            ns1:hasTarget <https://maytetoscano.github.io/bblocks-bioclima/bblocks/bblock/ogc.bioclima.indicator.pci> ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/yaml" ;
            prof:hasArtifact <https://maytetoscano.github.io/bblocks-bioclima/build/annotated/bioclima/zonification/bioclimatic-zone/schema.yaml> ;
            prof:hasRole role:schema ] ;
    bblocks:dependsOn <bblocks://ogc.bioclima.coveragejson.bioclima-coverage>,
        <bblocks://ogc.bioclima.indicator.indicator-definition>,
        <bblocks://ogc.bioclima.indicator.pci>,
        <bblocks://ogc.bioclima.policy.policy-alignment>,
        <bblocks://ogc.bioclima.provenance.indicator-provenance>,
        <bblocks://ogc.bioclima.zonification> ;
    bblocks:status <http://www.opengis.net/def/status/under-development> ;
    bblocks:validationPassed true .

