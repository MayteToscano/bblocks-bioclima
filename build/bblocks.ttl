<bblocks://ogc.bioclima.ebv.vap-coniferous> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Datatype ;
    rdfs:label "VAP Coniferous Finland 2001-2018" ;
    dct:abstract "Concrete EBV dataset: yearly maps of the start of the Vegetation Active Period in coniferous forests of Finland, 2001-2018, derived from MODIS Fractional Snow Cover. Packaged as a CoverageJSON document conformant to the bioclima-coverage profile. This is one of the two input EBVs consumed by the Phenological Change Indicator (PCI)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2024-11-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
