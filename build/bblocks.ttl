<bblocks://ogc.bioclima.policy.policy-alignment> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "Indicator ↔ Policy Alignment" ;
    dct:abstract "Schema describing how a Bioclima indicator aligns with a KMGBF target or an SDG goal. Every alignment record states a relationship type (informs, measures-progress-on, triggers-action-for, supports-reporting-on), an evidence strength (direct, indirect, contextual) and a multilingual justification. This block is the semantic bridge between gridded indicators (PCI, zonification) and the policy frameworks they support, and is what makes the register actionable for policy-makers."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2024-11-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://maytetoscano.github.io/bblocks-bioclima/build/generateddocs/json-full/bioclima/policy/policy-alignment/index.json> ],
